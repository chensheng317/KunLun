# ============================================================
# KunLun 后端环境变量模板
# 复制此文件为 .env 并填入真实值
# ⚠️ .env 文件已在 .gitignore 中，切勿提交到版本库
# ============================================================

# --- RunningHub (图片生成 · 视频生成 · 水印消除) ---
RUNNINGHUB_API_KEY=your_runninghub_api_key_here

# --- MiniMax (语音合成 TTS) ---
MINIMAX_API_KEY=your_minimax_api_key_here

# --- Mureka (AI 营销音乐) ---
MUREKA_API_KEY=your_mureka_api_key_here

# --- 火山引擎 / 即梦 (数字人直播形象) ---
VOLC_ACCESS_KEY=your_volc_access_key_here
VOLC_SECRET_KEY=your_volc_secret_key_here

# --- TOS 对象存储配置（即梦 API 要求图片/音频 URL 公网可访问，需通过 TOS 中转） ---
TOS_BUCKET=kunlun-digital-human
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing

# --- Coze 智能体 (JSON 提示词大师) ---
COZE_API_TOKEN=your_coze_api_token_here
COZE_BOT_ID=your_coze_bot_id_here

# --- AutoGLM (数字员工 — 手机自动化) ---
AUTOGLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AUTOGLM_MODEL=autoglm-phone
AUTOGLM_API_KEY=your_autoglm_api_key_here

# --- PostgreSQL 数据库配置 ---
# 本地开发：postgresql://postgres:YOUR_PASSWORD@localhost:5432/kunlun
# Render 部署：使用 Render 提供的 Internal Database URL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/kunlun

# --- JWT 认证配置 ---
# ⚠️ 生产环境请替换为强随机密钥（至少 32 位随机字符串）
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 公网注册开关 ---
# false = 关闭公网注册（仅允许预置账号登录，推荐测试/部署阶段使用）
# true  = 开放公网注册
ALLOW_PUBLIC_REGISTRATION=false

# --- CORS 跨域配置 ---
# 生产环境填入前端部署域名（逗号分隔多个）
# 不设置则默认允许 localhost 开发服务器
CORS_ORIGINS=https://your-frontend.onrender.com
